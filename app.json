{
  "expo": {
    "name": "baobab",
    "slug": "baobab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "baobab",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.samo.baobab",
      "associatedDomains": [
        "applinks:getbaobab.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "whatsapp"
        ]
      },
      "buildNumber": "24"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Baobab uses your contacts to invite friends. No contact data is stored or shared."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Baobab uses the camera to scan QR invitation codes. No photos or videos are captured or stored."
        }
      ],
      [
        "expo-dev-client",
        {
          "addGeneratedScheme": false,
          "launchMode": "launcher"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2eb9dbc-c750-49fa-91f0-71f344213d63"
      }
    }
  }
}
